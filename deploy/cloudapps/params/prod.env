APP_NAME=senate-prod
OPENSHIFT_PROJECT=calebhan
GIT_REPO=git@github.com:cssgunc/senate.git
GIT_REF=main
RUNTIME_ENVIRONMENT=production
FRONTEND_HOST=senate-prod-frontend-calebhan.apps.unc.edu
BACKEND_HOST=senate-prod-backend-calebhan.apps.unc.edu
NEXT_PUBLIC_API_URL=https://senate-prod-backend-calebhan.apps.unc.edu
CORS_ORIGINS=https://senate-prod-frontend-calebhan.apps.unc.edu
DB_NAME=senate_prod
DB_STORAGE_SIZE=8Gi
UPLOAD_STORAGE_SIZE=2Gi
MSSQL_MEMORY_REQUEST=1Gi
MSSQL_MEMORY_LIMIT=2Gi
BACKEND_MEMORY_REQUEST=256Mi
BACKEND_MEMORY_LIMIT=512Mi
FRONTEND_MEMORY_REQUEST=256Mi
FRONTEND_MEMORY_LIMIT=512Mi
